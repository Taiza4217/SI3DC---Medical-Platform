si3dc-backend/.pytest_cache/
si3dc-backend/.coverage
si3dc-backend/htmlcov/

# Ignore frontend unversionable artifacts
si3dc-frontend/node_modules/
si3dc-frontend/dist/
si3dc-frontend/build/
si3dc-frontend/coverage/
